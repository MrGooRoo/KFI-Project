{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrGooRoo/KFI-Project/schemas/financial_parse_result.schema.json",
  "title": "FinancialParseResult",
  "description": "Результат парсинга финансовой отчётности эмитента ВДО. Выходной контракт financial_parser.py → kfi_calculator.py",
  "type": "object",
  "required": [
    "emitter_id",
    "inn",
    "industry_group",
    "period",
    "source",
    "statements",
    "normalized_metrics",
    "coverage_flags"
  ],
  "additionalProperties": false,
  "$defs": {
    "RubleValue": {
      "type": "object",
      "description": "Значение строки отчётности в рублях с метаданными",
      "required": [
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": [
            "number",
            "null"
          ],
          "description": "Числовое значение в рублях. null = строка не найдена в отчёте"
        },
        "label": {
          "type": "string",
          "description": "Название строки на русском языке"
        },
        "unit": {
          "type": "string",
          "enum": [
            "RUB"
          ],
          "default": "RUB"
        },
        "source": {
          "type": "string",
          "enum": [
            "balance",
            "income_statement",
            "cashflow",
            "notes",
            "manual",
            "ifrs_fallback"
          ],
          "description": "Из какой формы взято значение"
        }
      }
    }
  },
  "properties": {
    "emitter_id": {
      "type": "string",
      "description": "Внутренний ключ эмитента"
    },
    "name": {
      "type": "string",
      "description": "Наименование эмитента"
    },
    "inn": {
      "type": "string",
      "description": "ИНН эмитента"
    },
    "industry_group": {
      "type": "integer",
      "enum": [
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "description": "Отраслевая группа — передаётся без изменений из запроса"
    },
    "period": {
      "type": "object",
      "required": [
        "period_type",
        "label"
      ],
      "additionalProperties": false,
      "properties": {
        "period_type": {
          "type": "string",
          "enum": [
            "annual",
            "semiannual",
            "quarterly"
          ]
        },
        "label": {
          "type": "string",
          "description": "Период в виде строки: 2025 или 2025Q3"
        },
        "date_from": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "date_to": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "report_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date",
          "description": "Дата подписания/публикации отчётности"
        }
      }
    },
    "source": {
      "type": "object",
      "required": [
        "provider",
        "reporting_standard",
        "parser_version",
        "downloaded_at"
      ],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "examples": [
            "e-disclosure.ru"
          ]
        },
        "company_id": {
          "type": [
            "string",
            "null"
          ],
          "description": "ID компании на портале"
        },
        "document_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri",
          "description": "Прямая ссылка на документ (обязательна для аудита)"
        },
        "document_type": {
          "type": "string",
          "enum": [
            "accounting_report",
            "interim_report",
            "notes",
            "ifrs_report",
            "annual_report"
          ]
        },
        "reporting_standard": {
          "type": "string",
          "enum": [
            "rsbu",
            "ifrs"
          ]
        },
        "file_format": {
          "type": "string",
          "enum": [
            "pdf",
            "html",
            "xls",
            "xlsx",
            "xbrl",
            "manual"
          ]
        },
        "downloaded_at": {
          "type": "string",
          "format": "date-time"
        },
        "parser_version": {
          "type": "string",
          "examples": [
            "0.1.0"
          ]
        }
      }
    },
    "statements": {
      "type": "object",
      "description": "Сырые строки форм отчётности с оригинальными кодами РСБУ",
      "additionalProperties": false,
      "properties": {
        "balance": {
          "type": "object",
          "description": "Бухгалтерский баланс (Форма №1)",
          "additionalProperties": false,
          "properties": {
            "1200": {
              "$ref": "#/$defs/RubleValue",
              "description": "Оборотные активы — нужен для A (ликвидность)"
            },
            "1210": {
              "$ref": "#/$defs/RubleValue",
              "description": "Запасы — нужен для быстрой ликвидности"
            },
            "1240": {
              "$ref": "#/$defs/RubleValue",
              "description": "Краткосрочные финансовые вложения"
            },
            "1250": {
              "$ref": "#/$defs/RubleValue",
              "description": "Денежные средства — нужен для абс. ликвидности"
            },
            "1300": {
              "$ref": "#/$defs/RubleValue",
              "description": "Собственный капитал — нужен для B и C"
            },
            "1410": {
              "$ref": "#/$defs/RubleValue",
              "description": "Долгосрочные заёмные средства"
            },
            "1500": {
              "$ref": "#/$defs/RubleValue",
              "description": "Краткосрочные обязательства — знаменатель A"
            },
            "1510": {
              "$ref": "#/$defs/RubleValue",
              "description": "Краткосрочные заёмные средства"
            },
            "1600": {
              "$ref": "#/$defs/RubleValue",
              "description": "Валюта баланса (итог активов)"
            }
          }
        },
        "income_statement": {
          "type": "object",
          "description": "Отчёт о финансовых результатах (Форма №2)",
          "additionalProperties": false,
          "properties": {
            "2110": {
              "$ref": "#/$defs/RubleValue",
              "description": "Выручка — знаменатель C (EBITDA Margin, CFO Margin)"
            },
            "2200": {
              "$ref": "#/$defs/RubleValue",
              "description": "Прибыль от продаж — proxy EBIT/EBITDA при отс. амортизации"
            },
            "2330": {
              "$ref": "#/$defs/RubleValue",
              "description": "Проценты к уплате — знаменатель ICR (блок A)"
            },
            "2400": {
              "$ref": "#/$defs/RubleValue",
              "description": "Чистая прибыль — нужна для ROE и D3 Cash Conversion"
            }
          }
        },
        "cashflow": {
          "type": "object",
          "description": "Отчёт о движении денежных средств (Форма №4)",
          "additionalProperties": false,
          "properties": {
            "4110": {
              "$ref": "#/$defs/RubleValue",
              "description": "Поступления от текущих операций — proxy CFO"
            },
            "4120": {
              "$ref": "#/$defs/RubleValue",
              "description": "Платежи по текущим операциям (для чистого CFO)"
            },
            "4100": {
              "$ref": "#/$defs/RubleValue",
              "description": "Чистые денежные средства от текущих операций (CFO итог)"
            },
            "4220": {
              "$ref": "#/$defs/RubleValue",
              "description": "Платежи на приобретение ОС/НМА — proxy CAPEX"
            }
          }
        },
        "prev_period": {
          "type": [
            "object",
            "null"
          ],
          "description": "Данные предыдущего периода для расчёта динамики (C3, D4). Та же структура, упрощённая.",
          "additionalProperties": false,
          "properties": {
            "period_label": {
              "type": "string",
              "description": "Метка предыдущего периода, например 2024"
            },
            "2110": {
              "$ref": "#/$defs/RubleValue"
            },
            "2400": {
              "$ref": "#/$defs/RubleValue"
            },
            "4100": {
              "$ref": "#/$defs/RubleValue"
            }
          }
        },
        "notes": {
          "type": "object",
          "description": "Данные из пояснений к отчётности. Ключи зависят от отраслевой группы.",
          "additionalProperties": false,
          "properties": {
            "amortization": {
              "$ref": "#/$defs/RubleValue",
              "description": "Амортизация — нужна для точного EBITDA (все группы)"
            },
            "interest_income": {
              "$ref": "#/$defs/RubleValue",
              "description": "Процентные доходы (группы 2 МФО, 3 Лизинг)"
            },
            "npl_90_plus": {
              "$ref": "#/$defs/RubleValue",
              "description": "Просрочка 90+ (группа 2 МФО — блок A)"
            },
            "loan_loss_reserves": {
              "$ref": "#/$defs/RubleValue",
              "description": "Резервы под обесценение портфеля (группа 2 МФО)"
            },
            "leasing_portfolio_net": {
              "$ref": "#/$defs/RubleValue",
              "description": "Лизинговый портфель нетто (группа 3 — блок A)"
            },
            "lease_payments_received": {
              "$ref": "#/$defs/RubleValue",
              "description": "Лизинговые платежи полученные (группа 3 — блок D)"
            },
            "escrow_balance": {
              "$ref": "#/$defs/RubleValue",
              "description": "Остаток на счетах эскроу (группа 1 Девелопмент — K_escrow)"
            },
            "project_finance_debt": {
              "$ref": "#/$defs/RubleValue",
              "description": "Задолженность по проектному финансированию (группа 1)"
            },
            "nmfk1_ratio": {
              "type": [
                "number",
                "null"
              ],
              "description": "Норматив НМФК1 = СК/Активы в % (группа 2 МФО — из реестра ЦБ)"
            },
            "overdue_portfolio": {
              "$ref": "#/$defs/RubleValue",
              "description": "Просроченный портфель (группы 2, 3)"
            }
          }
        }
      }
    },
    "normalized_metrics": {
      "type": "object",
      "description": "Канонические метрики для kfi_calculator.py. Все суммы в рублях. null = данные отсутствуют.",
      "additionalProperties": false,
      "properties": {
        "assets_current": {
          "type": [
            "number",
            "null"
          ],
          "description": "Оборотные активы (стр. 1200)"
        },
        "inventory": {
          "type": [
            "number",
            "null"
          ],
          "description": "Запасы (стр. 1210)"
        },
        "short_term_financial_investments": {
          "type": [
            "number",
            "null"
          ],
          "description": "КФВ (стр. 1240)"
        },
        "cash": {
          "type": [
            "number",
            "null"
          ],
          "description": "Денежные средства (стр. 1250)"
        },
        "liabilities_short": {
          "type": [
            "number",
            "null"
          ],
          "description": "Краткосрочные обязательства (стр. 1500)"
        },
        "ebit": {
          "type": [
            "number",
            "null"
          ],
          "description": "Прибыль от продаж = proxy EBIT (стр. 2200)"
        },
        "interest_expense": {
          "type": [
            "number",
            "null"
          ],
          "description": "Проценты к уплате (стр. 2330)"
        },
        "equity": {
          "type": [
            "number",
            "null"
          ],
          "description": "Собственный капитал (стр. 1300)"
        },
        "debt_long": {
          "type": [
            "number",
            "null"
          ],
          "description": "Долгосрочный долг (стр. 1410)"
        },
        "debt_short": {
          "type": [
            "number",
            "null"
          ],
          "description": "Краткосрочный долг (стр. 1510)"
        },
        "assets_total": {
          "type": [
            "number",
            "null"
          ],
          "description": "Валюта баланса (стр. 1600)"
        },
        "ebitda": {
          "type": [
            "number",
            "null"
          ],
          "description": "EBITDA = EBIT + амортизация. null если амортизация не найдена."
        },
        "amortization": {
          "type": [
            "number",
            "null"
          ],
          "description": "Амортизация (из пояснений). null допускается — см. флаг ebitda_approximated"
        },
        "revenue": {
          "type": [
            "number",
            "null"
          ],
          "description": "Выручка (стр. 2110)"
        },
        "profit_sales": {
          "type": [
            "number",
            "null"
          ],
          "description": "Прибыль от продаж (стр. 2200) — используется как proxy EBIT/EBITDA"
        },
        "net_profit": {
          "type": [
            "number",
            "null"
          ],
          "description": "Чистая прибыль (стр. 2400)"
        },
        "revenue_prev": {
          "type": [
            "number",
            "null"
          ],
          "description": "Выручка предыдущего периода — для C3 динамика"
        },
        "cfo": {
          "type": [
            "number",
            "null"
          ],
          "description": "Чистый денежный поток от текущих операций (стр. 4100)"
        },
        "capex": {
          "type": [
            "number",
            "null"
          ],
          "description": "CAPEX = платежи на приобретение ОС (стр. 4220)"
        },
        "fcf": {
          "type": [
            "number",
            "null"
          ],
          "description": "Свободный денежный поток = CFO - CAPEX (рассчитывается парсером)"
        },
        "cfo_prev": {
          "type": [
            "number",
            "null"
          ],
          "description": "CFO предыдущего периода — для D4 динамика"
        },
        "escrow_balance": {
          "type": [
            "number",
            "null"
          ],
          "description": "Эскроу-счета (группа 1 — K_escrow в блоке B)"
        },
        "project_finance_debt": {
          "type": [
            "number",
            "null"
          ],
          "description": "Проектный финансовый долг (группа 1)"
        },
        "npl_90_plus": {
          "type": [
            "number",
            "null"
          ],
          "description": "NPL 90+ (группа 2 — покрытие резервами в блоке A)"
        },
        "loan_loss_reserves": {
          "type": [
            "number",
            "null"
          ],
          "description": "Резервы под обесценение (группа 2)"
        },
        "nmfk1_ratio": {
          "type": [
            "number",
            "null"
          ],
          "description": "НМФК1 норматив ЦБ в % (группа 2 — блок A)"
        },
        "interest_income": {
          "type": [
            "number",
            "null"
          ],
          "description": "Процентные доходы — знаменатель CFO Margin для МФО/Лизинга (D1)"
        },
        "leasing_portfolio_net": {
          "type": [
            "number",
            "null"
          ],
          "description": "Лизинговый портфель нетто (группа 3 — блок A)"
        },
        "lease_payments_received": {
          "type": [
            "number",
            "null"
          ],
          "description": "Лизинговые платежи — знаменатель CFO Margin (группа 3, D1)"
        },
        "overdue_portfolio": {
          "type": [
            "number",
            "null"
          ],
          "description": "Просроченный портфель (группы 2, 3)"
        }
      }
    },
    "coverage_flags": {
      "type": "object",
      "description": "Флаги качества и полноты данных. Используются kfi_calculator.py для корректировок и штрафов.",
      "required": [
        "has_balance",
        "has_income_statement",
        "has_cashflow"
      ],
      "additionalProperties": false,
      "properties": {
        "has_balance": {
          "type": "boolean",
          "description": "Форма №1 найдена и разобрана"
        },
        "has_income_statement": {
          "type": "boolean",
          "description": "Форма №2 найдена и разобрана"
        },
        "has_cashflow": {
          "type": "boolean",
          "description": "Форма №4 (ОДДС) найдена и разобрана"
        },
        "has_notes": {
          "type": "boolean",
          "description": "Пояснения найдены (нужны для групп 1, 2, 3)"
        },
        "has_prev_period": {
          "type": "boolean",
          "description": "Данные предыдущего периода доступны"
        },
        "has_required_core_metrics": {
          "type": "boolean",
          "description": "Все ключевые поля normalized_metrics заполнены (не null)"
        },
        "missing_critical_metrics": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Список ключей normalized_metrics со значением null. Если >= 3 → штраф data_missing по правилу 4.3"
        },
        "ebitda_approximated": {
          "type": "boolean",
          "default": false,
          "description": "EBITDA рассчитана как proxy (без амортизации). Информационный флаг по методологии."
        },
        "used_ifrs_fallback": {
          "type": "boolean",
          "default": false,
          "description": "Использован МСФО вместо РСБУ"
        },
        "data_missing_penalty": {
          "type": "boolean",
          "default": false,
          "description": "Активен штраф за недостаток данных (>= 3 критических поля = null) → КФИ × 0.90"
        },
        "revenue_quality_risk": {
          "type": "boolean",
          "default": false,
          "description": "Рост выручки > 50% при падении CFO → флаг по правилу 4.3 → КФИ × 0.90"
        },
        "industry_notes_required": {
          "type": "boolean",
          "description": "Пояснения обязательны для данной отраслевой группы (true для групп 1, 2, 3)"
        },
        "industry_notes_missing": {
          "type": "boolean",
          "default": false,
          "description": "Пояснения требуются (группы 1/2/3), но не найдены — часть метрик будет null"
        }
      }
    },
    "parser_notes": {
      "type": "array",
      "description": "Человекочитаемые пометки парсера: о fallback, эвристиках, ручных правках, предупреждениях",
      "items": {
        "type": "string"
      },
      "examples": [
        [
          "EBITDA не может быть рассчитана точно — амортизация не выделена в пояснениях."
        ],
        [
          "Для группы 2 найдено значение NPL и резервов в табл. 4.3 пояснений."
        ],
        [
          "Строка 4100 отсутствует — CFO рассчитан как 4110 - 4120."
        ]
      ]
    }
  }
}