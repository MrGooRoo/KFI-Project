{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrGooRoo/KFI-Project/schemas/financial_parse_request.schema.json",
  "title": "FinancialParseRequest",
  "description": "Запрос на сбор и парсинг финансовой отчётности эмитента ВДО (Этап 4 KFI-Project)",
  "type": "object",
  "required": [
    "emitter_id",
    "name",
    "inn",
    "industry_group",
    "report_request"
  ],
  "additionalProperties": false,
  "properties": {
    "emitter_id": {
      "type": "string",
      "description": "Внутренний ключ эмитента в проекте (например, CARMONEY, SELTL)",
      "pattern": "^[A-Z0-9_]+$",
      "examples": [
        "CARMONEY",
        "SELTL"
      ]
    },
    "name": {
      "type": "string",
      "description": "Официальное наименование эмитента для поиска на e-disclosure",
      "examples": [
        "ПАО «КарМани»"
      ]
    },
    "inn": {
      "type": "string",
      "description": "ИНН — основной идентификатор для поиска и сверки отчётности",
      "pattern": "^[0-9]{10,12}$",
      "examples": [
        "7719451419"
      ]
    },
    "industry_group": {
      "type": "integer",
      "description": "Отраслевая группа 1–7 по методологии KFI v2.0. Определяет нормы блоков A и B.",
      "enum": [
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "enumDescriptions": [
        "1 — Девелопмент и строительство",
        "2 — МФО и потребкредитование",
        "3 — Лизинг",
        "4 — Торговля и ритейл",
        "5 — Производство и промышленность",
        "6 — Транспорт и логистика",
        "7 — Прочие и диверсифицированные"
      ]
    },
    "report_request": {
      "type": "object",
      "description": "Параметры нужного отчётного периода и типа отчётности",
      "required": [
        "period_type",
        "period",
        "reporting_standard"
      ],
      "additionalProperties": false,
      "properties": {
        "period_type": {
          "type": "string",
          "enum": [
            "annual",
            "semiannual",
            "quarterly"
          ],
          "description": "Тип периода отчётности"
        },
        "period": {
          "type": "string",
          "description": "Период: год (2025) или год+квартал (2025Q3)",
          "pattern": "^[0-9]{4}(Q[1-4])?$",
          "examples": [
            "2025",
            "2025Q3"
          ]
        },
        "reporting_standard": {
          "type": "string",
          "enum": [
            "rsbu",
            "ifrs"
          ],
          "description": "Предпочтительный стандарт отчётности: РСБУ (rsbu) или МСФО (ifrs)"
        },
        "need_notes": {
          "type": "boolean",
          "default": true,
          "description": "Требовать ли пояснения к отчётности (нужны для групп 1, 2, 3)"
        },
        "need_cashflow": {
          "type": "boolean",
          "default": true,
          "description": "Требовать ли ОДДС (Форма №4 — нужна для блока D)"
        },
        "need_prev_period": {
          "type": "boolean",
          "default": true,
          "description": "Требовать ли данные предыдущего периода для расчёта динамики (блоки C3, D4)"
        },
        "allow_ifrs_fallback": {
          "type": "boolean",
          "default": false,
          "description": "Разрешить ли fallback на МСФО если РСБУ недоступна"
        }
      }
    },
    "source_hints": {
      "type": "object",
      "description": "Необязательные подсказки для ускорения поиска на e-disclosure",
      "additionalProperties": false,
      "properties": {
        "edisclosure_company_id": {
          "type": [
            "string",
            "null"
          ],
          "description": "ID компании на e-disclosure.ru (часть URL: /portal/company.aspx?id=XXXXX)",
          "examples": [
            "8657"
          ]
        },
        "edisclosure_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri",
          "description": "Прямая ссылка на страницу компании на e-disclosure"
        },
        "preferred_document_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "accounting_report",
              "interim_report",
              "notes",
              "ifrs_report",
              "annual_report"
            ]
          },
          "description": "Предпочтительные типы документов для поиска (type=3 — бухотчётность)"
        }
      }
    }
  }
}