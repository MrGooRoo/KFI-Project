{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/MrGooRoo/KFI-Project/main/data/schema.json",
  "title": "KFI Project Data Schema",
  "description": "JSON Schema для валидации данных эмитентов и расчётов КФИ v2.0",
  "version": "2.0.0",

  "definitions": {

    "industry_group": {
      "type": "integer",
      "minimum": 1,
      "maximum": 7,
      "description": "Отраслевая группа: 1-Девелопмент, 2-МФО, 3-Лизинг, 4-Торговля, 5-Производство, 6-Транспорт, 7-Прочие"
    },

    "kfi_category": {
      "type": "string",
      "enum": ["Надёжный", "Стабильный", "Умеренный риск", "Высокий риск", "Критический"],
      "description": "Категория КФИ по шкале оценки"
    },

    "block_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Балл блока по шкале 0-100"
    },

    "risk_flags": {
      "type": "object",
      "description": "Флаги риска эмитента",
      "properties": {
        "bankruptcy_risk": {
          "type": "boolean",
          "description": "Иски о банкротстве или уголовные дела -> КФИ <= 30"
        },
        "revenue_quality_risk": {
          "type": "boolean",
          "description": "Рост выручки > 50% при падении CFO -> КФИ x 0.90"
        },
        "bond_concentration_risk": {
          "type": "boolean",
          "description": "Долг по облигациям > 60% финдолга -> КФИ x 0.95"
        },
        "data_missing": {
          "type": "boolean",
          "description": "3+ критических показателя отсутствуют -> КФИ x 0.90"
        },
        "young_issuer": {
          "type": "boolean",
          "description": "История менее 2 лет -> КФИ <= 50"
        },
        "ebitda_approximated": {
          "type": "boolean",
          "description": "Амортизация не выделена, EBITDA = прибыль от продаж (информационный флаг)"
        }
      },
      "required": [
        "bankruptcy_risk",
        "revenue_quality_risk",
        "bond_concentration_risk",
        "data_missing",
        "young_issuer",
        "ebitda_approximated"
      ],
      "additionalProperties": false
    },

    "emitter": {
      "type": "object",
      "description": "Эмитент облигаций",
      "properties": {
        "id": {
          "type": "string",
          "description": "Уникальный идентификатор эмитента"
        },
        "name": {
          "type": "string",
          "description": "Полное наименование эмитента"
        },
        "inn": {
          "type": "string",
          "pattern": "^[0-9]{10}$|^[0-9]{12}$",
          "description": "ИНН эмитента (10 или 12 цифр)"
        },
        "industry_group": {
          "$ref": "#/definitions/industry_group"
        },
        "ticker": {
          "type": "string",
          "description": "Тикер на MOEX (если есть)"
        },
        "isin": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Список ISIN активных выпусков облигаций"
        },
        "created_at": {
          "type": "string",
          "format": "date",
          "description": "Дата добавления в систему"
        },
        "updated_at": {
          "type": "string",
          "format": "date",
          "description": "Дата последнего обновления"
        }
      },
      "required": ["id", "name", "inn", "industry_group", "created_at", "updated_at"],
      "additionalProperties": false
    },

    "block_scores_detail": {
      "type": "object",
      "description": "Детальные баллы по блокам A-F",
      "properties": {
        "block_a": { "$ref": "#/definitions/block_score" },
        "block_b": { "$ref": "#/definitions/block_score" },
        "block_c": { "$ref": "#/definitions/block_score" },
        "block_d": { "$ref": "#/definitions/block_score" },
        "block_e": { "$ref": "#/definitions/block_score" },
        "block_f": { "$ref": "#/definitions/block_score" }
      },
      "required": ["block_a", "block_b", "block_c", "block_d", "block_e", "block_f"],
      "additionalProperties": false
    },

    "calculation": {
      "type": "object",
      "description": "Расчёт КФИ для эмитента за период",
      "properties": {
        "id": {
          "type": "string",
          "description": "Уникальный идентификатор расчёта"
        },
        "emitter_id": {
          "type": "string",
          "description": "Ссылка на эмитента"
        },
        "period": {
          "type": "string",
          "pattern": "^[0-9]{4}-(Q1|Q2|Q3|Q4)$",
          "description": "Отчётный период в формате YYYY-Q# (например: 2024-Q3)"
        },
        "report_date": {
          "type": "string",
          "format": "date",
          "description": "Дата публикации отчётности на e-disclosure"
        },
        "source_url": {
          "type": "string",
          "format": "uri",
          "description": "Ссылка на источник отчётности"
        },
        "block_scores": {
          "$ref": "#/definitions/block_scores_detail"
        },
        "kfi_base": {
          "$ref": "#/definitions/block_score",
          "description": "КФИ базовый до корректировок"
        },
        "kfi_final": {
          "$ref": "#/definitions/block_score",
          "description": "КФИ итоговый после всех корректировок"
        },
        "category": {
          "$ref": "#/definitions/kfi_category"
        },
        "risk_flags": {
          "$ref": "#/definitions/risk_flags"
        },
        "verified_by": {
          "type": "string",
          "description": "Кто верифицировал расчёт"
        },
        "verified_at": {
          "type": ["string", "null"],
          "format": "date",
          "description": "Дата верификации редактором"
        },
        "calculated_at": {
          "type": "string",
          "format": "date",
          "description": "Дата расчёта"
        }
      },
      "required": [
        "id",
        "emitter_id",
        "period",
        "report_date",
        "block_scores",
        "kfi_base",
        "kfi_final",
        "category",
        "risk_flags",
        "calculated_at"
      ],
      "additionalProperties": false
    }
  },

  "oneOf": [
    {
      "title": "Список эмитентов (emitters.json)",
      "type": "object",
      "properties": {
        "$schema": { "type": "string" },
        "emitters": {
          "type": "array",
          "items": { "$ref": "#/definitions/emitter" },
          "minItems": 1
        }
      },
      "required": ["emitters"],
      "additionalProperties": false
    },
    {
      "title": "Расчёт КФИ (calculations/*.json)",
      "type": "object",
      "properties": {
        "$schema": { "type": "string" },
        "calculations": {
          "type": "array",
          "items": { "$ref": "#/definitions/calculation" },
          "minItems": 1
        }
      },
      "required": ["calculations"],
      "additionalProperties": false
    }
  ]
}
